# Canonical config for homelab-demucs.
# Used by Docker Compose (env_file), Windows NSSM (AppEnvironmentExtra),
# and Linux systemd (copy to /etc/demucs/demucs.env).

# Absolute path to a Python interpreter. Required when .venv/ does not yet
# exist and python.exe is not on PATH (e.g. NSSM running as LocalSystem).
DEMUCS_PYTHON_EXE=/absolute/path/to/python3

# HTTP bind. Port ownership stays in homelab-infra.
HOST=0.0.0.0
PORT=20033

# Storage. DATA_ROOT is the host path mounted into the container at /data;
# STORAGE_ROOT is the in-process path the service writes to.
DATA_ROOT=/mnt/data/demucs
STORAGE_ROOT=/data

MAX_CONCURRENT_JOBS=1
DEMUCS_DEFAULT_MODEL=htdemucs
DEMUCS_MODELS=htdemucs,htdemucs_ft,mdx,mdx_q
DEMUCS_BIN=demucs
DEMUCS_DEVICE=cuda
JOB_TIMEOUT_SECONDS=180
OUTPUT_FORMAT_VERSION=v1-wav

# Windows NSSM service identity (optional; defaults shown).
# These are consumed by scripts/up.ps1 and not passed to the app.
# NSSM_SERVICE_NAME=homelab-demucs
# NSSM_DISPLAY_NAME=homelab-demucs separation API
# NSSM_DESCRIPTION=Host-run Demucs separation HTTP service
