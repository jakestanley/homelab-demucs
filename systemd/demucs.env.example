# Copy this file to /etc/demucs/demucs.env on the host.
# Keep PORT aligned with homelab-infra; do not invent a local override.

DEMUCS_PYTHON_EXE=/absolute/path/to/python3
HOST=0.0.0.0
PORT=SET_FROM_HOMELAB_INFRA
STORAGE_ROOT=/var/lib/demucs
MAX_CONCURRENT_JOBS=1
DEMUCS_DEFAULT_MODEL=htdemucs
DEMUCS_MODELS=htdemucs,htdemucs_ft,mdx,mdx_q
DEMUCS_BIN=demucs
DEMUCS_DEVICE=cuda
JOB_TIMEOUT_SECONDS=180
OUTPUT_FORMAT_VERSION=v1-wav
